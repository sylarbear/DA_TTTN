# =============================================
# EngPath - Cấu hình môi trường
# Copy file này thành .env và điền giá trị thực
# =============================================

# App Environment: development | production
APP_ENV=development

# Site URL (để trống để tự động detect từ HTTP_HOST)
SITE_URL=

# MySQL Database
DB_HOST=localhost
DB_NAME=english_master
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Google OAuth 2.0 (đăng nhập bằng Google)
# Lấy tại: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost/DA_TTTN/public/auth/googleCallback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI API Key (dùng cho Speaking AI + Chatbot)
# Lấy tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Casso Webhook (tự động xác nhận thanh toán chuyển khoản)
# Lấy tại: https://casso.vn
CASSO_API_KEY=
CASSO_WEBHOOK_SECRET=
