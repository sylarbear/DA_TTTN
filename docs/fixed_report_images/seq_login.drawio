<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Seq-Login">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="850">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="t1" value="Sequence Diagram: Đăng nhập (Login)" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- LIFELINES: simple boxes as column headers -->
        <mxCell id="h1" value="Người dùng" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h2" value="AuthController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="240" y="50" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h3" value="User Model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="460" y="50" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h4" value="Database" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="45" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h5" value="GoogleOAuth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="50" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6" value="Google API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="50" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- Dashed lifelines -->
        <mxCell id="l1" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="90" y="90"/><mxPoint x="90" y="780"/></mxGeometry></mxCell>
        <mxCell id="l2" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="90"/><mxPoint x="300" y="780"/></mxGeometry></mxCell>
        <mxCell id="l3" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="90"/><mxPoint x="510" y="780"/></mxGeometry></mxCell>
        <mxCell id="l4" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="710" y="95"/><mxPoint x="710" y="780"/></mxGeometry></mxCell>
        <mxCell id="l5" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="915" y="90"/><mxPoint x="915" y="780"/></mxGeometry></mxCell>
        <mxCell id="l6" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1100" y="90"/><mxPoint x="1100" y="780"/></mxGeometry></mxCell>

        <!-- STANDARD LOGIN FLOW (left side) -->

        <!-- 1. POST /auth/login -->
        <mxCell id="s1" value="POST /auth/login (username, password)" style="endArrow=block;html=1;fontSize=11;fontColor=#333333;exitX=1;exitY=0;entryX=0;entryY=0;" edge="1" parent="1" source="l1" target="l2">
          <mxGeometry relative="1" as="geometry"><mxPoint x="90" y="110" as="sourcePoint"/><mxPoint x="300" y="110" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- 2. authenticate() -->
        <mxCell id="s2" value="authenticate(username, password)" style="endArrow=block;html=1;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="145" as="sourcePoint"/><mxPoint x="510" y="145" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- 3. SQL query -->
        <mxCell id="s3" value="SELECT * FROM users WHERE username=? OR email=?" style="endArrow=block;html=1;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="510" y="180" as="sourcePoint"/><mxPoint x="710" y="180" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- 4. return user -->
        <mxCell id="s4" value="user row (or null)" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="710" y="210" as="sourcePoint"/><mxPoint x="510" y="210" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- 5. verify password -->
        <mxCell id="n1" value="password_verify()" style="text;html=1;fontSize=10;align=center;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="460" y="230" width="100" height="20" as="geometry" />
        </mxCell>

        <!-- 6. return user data -->
        <mxCell id="s5" value="user data (if password match)" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="510" y="265" as="sourcePoint"/><mxPoint x="300" y="265" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- 7. session setup -->
        <mxCell id="n2" value="session_regenerate_id()&#xa;Set SESSION vars&#xa;Check membership expiry" style="text;html=1;fontSize=10;align=left;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="190" y="290" width="160" height="55" as="geometry" />
        </mxCell>

        <!-- 8. redirect -->
        <mxCell id="s6" value="redirect(role=admin ? 'admin' : '')" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="360" as="sourcePoint"/><mxPoint x="90" y="360" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ===== GOOGLE OAUTH FLOW (right side) ===== -->
        <mxCell id="d1" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#cccccc;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="10" y="420"/><mxPoint x="1180" y="420"/></mxGeometry>
        </mxCell>
        <mxCell id="d1t" value="Google OAuth Flow (alternative)" style="text;html=1;fontSize=12;fontStyle=2;fontColor=#888888;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="425" width="200" height="20" as="geometry" />
        </mxCell>

        <!-- G1: GET /auth/google -->
        <mxCell id="g1" value="GET /auth/google" style="endArrow=block;html=1;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="90" y="455" as="sourcePoint"/><mxPoint x="300" y="455" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- G2: getAuthUrl -->
        <mxCell id="g2" value="getAuthUrl()" style="endArrow=block;html=1;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="485" as="sourcePoint"/><mxPoint x="915" y="485" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- G3: redirect to Google -->
        <mxCell id="g3" value="redirect to Google consent screen" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="515" as="sourcePoint"/><mxPoint x="90" y="515" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- G4: User authorizes -->
        <mxCell id="g4" value="User authorizes &amp; Google redirects with ?code=" style="endArrow=block;html=1;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="90" y="550" as="sourcePoint"/><mxPoint x="300" y="550" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- G5: callback processing -->
        <mxCell id="g5" value="verifyState(state)" style="endArrow=block;html=1;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="580" as="sourcePoint"/><mxPoint x="915" y="580" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- G6: getAccessToken -->
        <mxCell id="g6" value="getAccessToken(code)" style="endArrow=block;html=1;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="610" as="sourcePoint"/><mxPoint x="915" y="610" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="g7" value="POST /token" style="endArrow=block;html=1;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="915" y="640" as="sourcePoint"/><mxPoint x="1100" y="640" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="g8" value="access_token" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1100" y="670" as="sourcePoint"/><mxPoint x="915" y="670" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- G9: getUserInfo -->
        <mxCell id="g9" value="getUserInfo(access_token)" style="endArrow=block;html=1;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="700" as="sourcePoint"/><mxPoint x="915" y="700" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="g10" value="GET /userinfo" style="endArrow=block;html=1;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="915" y="730" as="sourcePoint"/><mxPoint x="1100" y="730" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="g11" value="user info (email, name, picture)" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1100" y="760" as="sourcePoint"/><mxPoint x="915" y="760" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- G12: findOrCreateByGoogle -->
        <mxCell id="g12" value="findOrCreateByGoogle(googleUser)" style="endArrow=block;html=1;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="760" as="sourcePoint"/><mxPoint x="510" y="760" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- G13: return user -->
        <mxCell id="g13" value="user data" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="510" y="790" as="sourcePoint"/><mxPoint x="300" y="790" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- alt box for wrong password -->
        <mxCell id="alt1" value="alt [password wrong]" style="shape=step;perimeter=stepPerimeter;whiteSpace=wrap;html=1;fontSize=10;fillColor=#f8cecc;strokeColor=#b85450;size=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="130" width="280" height="50" as="geometry" />
        </mxCell>

        <mxCell id="s4a" value="return null" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#cc0000;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="510" y="240" as="sourcePoint"/><mxPoint x="300" y="240" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="s5a" value="show error message" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#cc0000;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="280" as="sourcePoint"/><mxPoint x="90" y="280" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
