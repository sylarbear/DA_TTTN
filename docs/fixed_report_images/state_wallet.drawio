<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="State-Wallet">
    <mxGraphModel dx="800" dy="550" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="550">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <mxCell id="t1" value="State Diagram: Trạng thái Giao dịch Ví (Wallet Transaction)" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="500" height="30" as="geometry" />
        </mxCell>

        <!-- Initial -->
        <mxCell id="start" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="140" y="55" width="20" height="20" as="geometry" />
        </mxCell>

        <!-- Pending -->
        <mxCell id="pending" value="PENDING&#xa;(Chờ duyệt)&#xa;&#xa;deposit / withdraw&#xa;amount &gt; 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="init1" value="User tạo deposit/withdraw" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="150" y="75"/><mxPoint x="150" y="100"/></mxGeometry>
        </mxCell>

        <!-- Completed -->
        <mxCell id="completed" value="COMPLETED&#xa;(Hoàn thành)&#xa;&#xa;balance_after được ghi&#xa;processed_at = NOW()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="100" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Rejected -->
        <mxCell id="rejected" value="REJECTED&#xa;(Từ chối)&#xa;&#xa;admin_note được ghi&#xa;processed_at = NOW()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="330" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Transitions -->
        <mxCell id="tr1" value="Admin duyệt (approveTransaction)&#xa;Deposit: balance += amount&#xa;Withdraw: balance -= amount" style="endArrow=block;html=1;fontSize=11;fontColor=#2d7a3a;exitX=1;exitY=0.35;entryX=0;entryY=0.35;rounded=1;" edge="1" parent="1" source="pending" target="completed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="tr2" value="Admin từ chối (rejectTransaction)&#xa;+ ghi admin_note" style="endArrow=block;html=1;fontSize=11;fontColor=#cc0000;exitX=1;exitY=0.65;entryX=0;entryY=0.3;rounded=1;" edge="1" parent="1" source="pending" target="rejected">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Direct completed for purchase/refund -->
        <mxCell id="direct" value="PURCHASE / REFUND&#xa;(Không qua pending)&#xa;&#xa;Mua Pro bằng ví → completed ngay&#xa;Hoàn tiền hủy đơn → completed ngay" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="280" width="200" height="90" as="geometry" />
        </mxCell>

        <mxCell id="start2" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="140" y="255" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="init2" value="System tự tạo (auto)" style="endArrow=block;html=1;fontSize=10;fontColor=#666666;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="150" y="275"/><mxPoint x="150" y="280"/></mxGeometry>
        </mxCell>

        <!-- Final -->
        <mxCell id="end" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#333333;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="535" y="470" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="f1" style="endArrow=block;html=1;fontSize=10;fontColor=#666666;" edge="1" parent="1" source="completed" target="end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f2" style="endArrow=block;html=1;fontSize=10;fontColor=#666666;" edge="1" parent="1" source="rejected" target="end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f3" style="endArrow=block;html=1;fontSize=10;fontColor=#666666;" edge="1" parent="1" source="direct" target="end">
          <mxGeometry relative="1" as="geometry"><mxPoint x="150" y="370"/><mxPoint x="150" y="485"/><mxPoint x="550" y="485"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
