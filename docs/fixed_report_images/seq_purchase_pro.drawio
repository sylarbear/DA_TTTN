<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Seq-PurchasePro">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <mxCell id="t1" value="Sequence Diagram: Mua gói Pro (Purchase Pro)" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- Headers -->
        <mxCell id="h1" value="Học viên" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="30" y="50" width="90" height="40" as="geometry"/></mxCell>
        <mxCell id="h2" value="MembershipController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="240" y="50" width="140" height="40" as="geometry"/></mxCell>
        <mxCell id="h3" value="Database" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="520" y="45" width="100" height="50" as="geometry"/></mxCell>

        <!-- Lifelines -->
        <mxCell id="l1" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="75" y="90"/><mxPoint x="75" y="800"/></mxGeometry></mxCell>
        <mxCell id="l2" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="90"/><mxPoint x="310" y="800"/></mxGeometry></mxCell>
        <mxCell id="l3" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="570" y="95"/><mxPoint x="570" y="800"/></mxGeometry></mxCell>

        <!-- ===== METHOD 1: Pay by Wallet ===== -->
        <mxCell id="ph1" value="Phương thức 1: Thanh toán bằng Ví (Wallet)" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#2d7a3a;" vertex="1" parent="1"><mxGeometry x="30" y="100" width="300" height="20" as="geometry"/></mxCell>

        <!-- M1 -->
        <mxCell id="m1" value="POST /membership/createOrder {plan_id}" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="75" y="130"/><mxPoint x="310" y="130"/></mxGeometry></mxCell>

        <mxCell id="m2" value="SELECT * FROM membership_plans WHERE id=?" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="160"/><mxPoint x="570" y="160"/></mxGeometry></mxCell>
        <mxCell id="m3" value="plan (name, price, duration_months)" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="570" y="180"/><mxPoint x="310" y="180"/></mxGeometry></mxCell>

        <mxCell id="n1" value="BEGIN TRANSACTION" style="text;html=1;fontSize=10;align=center;fillColor=#fff2cc;" vertex="1" parent="1"><mxGeometry x="240" y="200" width="130" height="20" as="geometry"/></mxCell>

        <mxCell id="m4" value="SELECT balance FROM users WHERE id=? FOR UPDATE" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="235"/><mxPoint x="570" y="235"/></mxGeometry></mxCell>
        <mxCell id="m5" value="currentBalance" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="570" y="255"/><mxPoint x="310" y="255"/></mxGeometry></mxCell>

        <!-- alt balance check -->
        <mxCell id="alt1" value="alt [balance &lt; price]" style="shape=step;perimeter=stepPerimeter;whiteSpace=wrap;html=1;fontSize=10;fillColor=#f8cecc;strokeColor=#b85450;size=8;" vertex="1" parent="1"><mxGeometry x="360" y="270" width="150" height="40" as="geometry"/></mxCell>
        <mxCell id="m5a" value="ROLLBACK + {error: 'Số dư không đủ'}" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#cc0000;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="305"/><mxPoint x="75" y="305"/></mxGeometry></mxCell>

        <mxCell id="n2" value="Calculate expired_at:&#xa;Nếu đang Pro thì extend từ expiry hiện tại&#xa;Nếu không thì từ now + duration_months" style="text;html=1;fontSize=10;align=left;fillColor=#d5e8d4;" vertex="1" parent="1"><mxGeometry x="200" y="330" width="230" height="50" as="geometry"/></mxCell>

        <mxCell id="m6" value="UPDATE users SET balance=balance-price, membership='pro', membership_expired_at=?" style="endArrow=block;html=1;fontSize=11;fontColor=#2d7a3a;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="395"/><mxPoint x="570" y="395"/></mxGeometry></mxCell>

        <mxCell id="m7" value="INSERT membership_orders (status='completed', payment_method='wallet')" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="425"/><mxPoint x="570" y="425"/></mxGeometry></mxCell>

        <mxCell id="m8" value="INSERT wallet_transactions (type='purchase', status='completed', balance_after)" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="455"/><mxPoint x="570" y="455"/></mxGeometry></mxCell>

        <mxCell id="n3" value="COMMIT" style="text;html=1;fontSize=10;align=center;fillColor=#d5e8d4;" vertex="1" parent="1"><mxGeometry x="280" y="480" width="80" height="20" as="geometry"/></mxCell>

        <mxCell id="n4" value="Update session: membership='pro',&#xa;membership_expired_at=..." style="text;html=1;fontSize=10;align=left;fillColor=#d5e8d4;" vertex="1" parent="1"><mxGeometry x="200" y="510" width="215" height="35" as="geometry"/></mxCell>

        <mxCell id="m9" value="{success, message, expired_at, new_balance}" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#2d7a3a;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="560"/><mxPoint x="75" y="560"/></mxGeometry></mxCell>

        <!-- ===== METHOD 2: Activation Code ===== -->
        <mxCell id="d1" style="endArrow=none;html=1;dashed=1;strokeColor=#cccccc;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="10" y="610"/><mxPoint x="680" y="610"/></mxGeometry></mxCell>
        <mxCell id="ph2" value="Phương thức 2: Kích hoạt mã Pro" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="30" y="620" width="230" height="20" as="geometry"/></mxCell>

        <mxCell id="a1" value="POST /membership/activate {code}" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="75" y="650"/><mxPoint x="310" y="650"/></mxGeometry></mxCell>

        <mxCell id="a2" value="SELECT ac.*, mp.duration_months FROM activation_codes ac JOIN membership_plans mp ON ac.plan_id=mp.id WHERE code=?" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="680"/><mxPoint x="570" y="680"/></mxGeometry></mxCell>
        <mxCell id="a3" value="activation (plan, is_used)" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="570" y="700"/><mxPoint x="310" y="700"/></mxGeometry></mxCell>

        <mxCell id="a4" value="Validate: code exists, not used" style="text;html=1;fontSize=10;fillColor=#e1d5e7;" vertex="1" parent="1"><mxGeometry x="240" y="715" width="160" height="20" as="geometry"/></mxCell>

        <mxCell id="a5" value="UPDATE activation_codes SET is_used=1, used_by=?, used_at=NOW()" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="750"/><mxPoint x="570" y="750"/></mxGeometry></mxCell>
        <mxCell id="a6" value="UPDATE users SET membership='pro', membership_expired_at=?" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="780"/><mxPoint x="570" y="780"/></mxGeometry></mxCell>
        <mxCell id="a7" value="INSERT membership_orders (status='completed', payment_method='activation_code', amount=0)" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="810"/><mxPoint x="570" y="810"/></mxGeometry></mxCell>

        <mxCell id="a8" value="{success, plan_name, expired_at}" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#9673a6;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="840"/><mxPoint x="75" y="840"/></mxGeometry></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
