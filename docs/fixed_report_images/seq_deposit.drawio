<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Seq-Deposit">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <mxCell id="t1" value="Sequence Diagram: Nạp tiền &amp; Duyệt giao dịch (Deposit)" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="500" height="30" as="geometry" />
        </mxCell>

        <!-- Headers -->
        <mxCell id="h1" value="Học viên" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="30" y="50" width="90" height="40" as="geometry"/></mxCell>
        <mxCell id="h2" value="WalletController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="230" y="50" width="120" height="40" as="geometry"/></mxCell>
        <mxCell id="h3" value="Database" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="460" y="45" width="100" height="50" as="geometry"/></mxCell>
        <mxCell id="h4" value="Admin" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="750" y="50" width="70" height="40" as="geometry"/></mxCell>
        <mxCell id="h5" value="AdminController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="930" y="50" width="120" height="40" as="geometry"/></mxCell>
        <mxCell id="h6" value="Database" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1100" y="45" width="80" height="50" as="geometry"/></mxCell>

        <!-- Lifelines -->
        <mxCell id="l1" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="75" y="90"/><mxPoint x="75" y="850"/></mxGeometry></mxCell>
        <mxCell id="l2" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="90"/><mxPoint x="290" y="850"/></mxGeometry></mxCell>
        <mxCell id="l3" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="95"/><mxPoint x="510" y="850"/></mxGeometry></mxCell>
        <mxCell id="l4" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="785" y="90"/><mxPoint x="785" y="850"/></mxGeometry></mxCell>
        <mxCell id="l5" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="990" y="90"/><mxPoint x="990" y="850"/></mxGeometry></mxCell>
        <mxCell id="l6" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1140" y="95"/><mxPoint x="1140" y="850"/></mxGeometry></mxCell>

        <!-- ===== PHASE 1: Student creates deposit ===== -->
        <mxCell id="p1" value="Student Phase: Tạo yêu cầu nạp tiền" style="text;html=1;fontSize=11;fontStyle=2;fontColor=#2d7a3a;" vertex="1" parent="1"><mxGeometry x="30" y="100" width="230" height="20" as="geometry"/></mxCell>

        <!-- 1 -->
        <mxCell id="m1" value="POST /wallet/createDeposit {amount, transfer_note}" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="75" y="130"/><mxPoint x="290" y="130"/></mxGeometry></mxCell>

        <!-- 2: validate -->
        <mxCell id="n1" value="Validate: 10k &lt;= amount &lt;= 10M&#xa;Check no pending deposit" style="text;html=1;fontSize=10;align=left;fillColor=#d5e8d4;" vertex="1" parent="1"><mxGeometry x="170" y="145" width="180" height="35" as="geometry"/></mxCell>

        <!-- 3: check pending -->
        <mxCell id="m2" value="SELECT COUNT(*) FROM wallet_transactions WHERE type='deposit' AND status='pending'" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="195"/><mxPoint x="510" y="195"/></mxGeometry></mxCell>
        <mxCell id="m3" value="count" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="215"/><mxPoint x="290" y="215"/></mxGeometry></mxCell>

        <!-- 4: insert -->
        <mxCell id="m4" value="INSERT wallet_transactions (type='deposit', status='pending', amount)" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="245"/><mxPoint x="510" y="245"/></mxGeometry></mxCell>
        <mxCell id="m5" value="OK" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="265"/><mxPoint x="290" y="265"/></mxGeometry></mxCell>

        <!-- 5: success response -->
        <mxCell id="m6" value="{success, message: 'Y/c nạp đã gửi, chờ Admin duyệt'}" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#2d7a3a;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="295"/><mxPoint x="75" y="295"/></mxGeometry></mxCell>

        <!-- Divider -->
        <mxCell id="d1" style="endArrow=none;html=1;dashed=1;strokeColor=#cccccc;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="10" y="340"/><mxPoint x="1180" y="340"/></mxGeometry></mxCell>
        <mxCell id="dt1" value="Thời gian trôi qua... (Admin vào xử lý)" style="text;html=1;fontSize=11;fontStyle=2;fontColor=#888888;align=center;" vertex="1" parent="1"><mxGeometry x="400" y="345" width="220" height="20" as="geometry"/></mxCell>

        <!-- ===== PHASE 2: Admin approves ===== -->
        <mxCell id="p2" value="Admin Phase: Duyệt giao dịch" style="text;html=1;fontSize=11;fontStyle=2;fontColor=#b85450;" vertex="1" parent="1"><mxGeometry x="750" y="370" width="170" height="20" as="geometry"/></mxCell>

        <!-- 6: view -->
        <mxCell id="m7" value="Xem danh sách giao dịch pending" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="785" y="400"/><mxPoint x="990" y="400"/></mxGeometry></mxCell>

        <mxCell id="m8" value="SELECT * FROM wallet_transactions WHERE status='pending'" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="990" y="425"/><mxPoint x="1140" y="425"/></mxGeometry></mxCell>
        <mxCell id="m9" value="transactions list" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1140" y="445"/><mxPoint x="990" y="445"/></mxGeometry></mxCell>

        <!-- 7: approve -->
        <mxCell id="m10" value="POST /admin/approveTransaction {id}" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="785" y="480"/><mxPoint x="990" y="480"/></mxGeometry></mxCell>

        <!-- 8: get tx -->
        <mxCell id="m11" value="SELECT * FROM wallet_transactions WHERE id=? AND status='pending'" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="990" y="510"/><mxPoint x="1140" y="510"/></mxGeometry></mxCell>
        <mxCell id="m12" value="transaction (type=deposit, amount)" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1140" y="530"/><mxPoint x="990" y="530"/></mxGeometry></mxCell>

        <!-- 9: BEGIN TXN -->
        <mxCell id="n2" value="BEGIN TRANSACTION" style="text;html=1;fontSize=10;align=center;fillColor=#fff2cc;" vertex="1" parent="1"><mxGeometry x="930" y="550" width="140" height="20" as="geometry"/></mxCell>

        <mxCell id="m13" value="SELECT balance FROM users WHERE id=? FOR UPDATE" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="990" y="585"/><mxPoint x="1140" y="585"/></mxGeometry></mxCell>
        <mxCell id="m14" value="currentBalance" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#666666;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1140" y="605"/><mxPoint x="990" y="605"/></mxGeometry></mxCell>

        <mxCell id="n3" value="newBalance = currentBalance + amount" style="text;html=1;fontSize=10;align=center;fillColor=#d5e8d4;" vertex="1" parent="1"><mxGeometry x="930" y="620" width="200" height="20" as="geometry"/></mxCell>

        <mxCell id="m15" value="UPDATE users SET balance=? WHERE id=?" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="990" y="655"/><mxPoint x="1140" y="655"/></mxGeometry></mxCell>

        <mxCell id="m16" value="UPDATE wallet_transactions SET status='completed', balance_after=?, processed_at=NOW()" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="990" y="685"/><mxPoint x="1140" y="685"/></mxGeometry></mxCell>

        <mxCell id="n4" value="COMMIT" style="text;html=1;fontSize=10;align=center;fillColor=#d5e8d4;" vertex="1" parent="1"><mxGeometry x="980" y="715" width="80" height="20" as="geometry"/></mxCell>

        <mxCell id="m17" value="{success, message}" style="endArrow=open;html=1;dashed=1;fontSize=11;fontColor=#2d7a3a;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="990" y="755"/><mxPoint x="785" y="755"/></mxGeometry></mxCell>

        <!-- Alt: reject -->
        <mxCell id="alt1" value="alt [reject]" style="shape=step;perimeter=stepPerimeter;whiteSpace=wrap;html=1;fontSize=10;fillColor=#f8cecc;strokeColor=#b85450;size=8;" vertex="1" parent="1"><mxGeometry x="400" y="800" width="250" height="35" as="geometry"/></mxCell>
        <mxCell id="m18" value="UPDATE wallet_transactions SET status='rejected', admin_note=?" style="endArrow=block;html=1;fontSize=10;fontColor=#cc0000;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="990" y="805"/><mxPoint x="1140" y="805"/></mxGeometry></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
