<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="State-Membership">
    <mxGraphModel dx="700" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="500">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <mxCell id="t1" value="State Diagram: Trạng thái Membership" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="180" y="10" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- Initial state -->
        <mxCell id="start" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="95" y="60" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="st1" value="" style="endArrow=block;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="105" y="80"/><mxPoint x="160" y="130"/></mxGeometry>
        </mxCell>

        <!-- State: Free -->
        <mxCell id="free" value="FREE&#xa;(Miễn phí)&#xa;membership='free'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- State: Pro -->
        <mxCell id="pro" value="PRO&#xa;(Hội viên trả phí)&#xa;membership='pro'&#xa;+ membership_expired_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="130" width="200" height="85" as="geometry" />
        </mxCell>

        <!-- Transitions -->
        <mxCell id="tr1" value="Mua gói Pro (ví)&#xa;Kích hoạt mã Pro&#xa;Admin duyệt đơn QR&#xa;Webhook Casso auto" style="endArrow=block;html=1;fontSize=11;fontColor=#2d7a3a;exitX=1;exitY=0.3;entryX=0;entryY=0.3;rounded=1;" edge="1" parent="1" source="free" target="pro">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="tr2" value="Hết hạn (expired_at &lt; now)&#xa;Admin downgrade thủ công" style="endArrow=block;html=1;fontSize=11;fontColor=#cc0000;exitX=0;exitY=0.7;entryX=1;entryY=0.7;rounded=1;" edge="1" parent="1" source="pro" target="free">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Self-loop: Extend Pro -->
        <mxCell id="tr3" value="Gia hạn khi đang Pro&#xa;(extend từ ngày hết hạn hiện tại)" style="endArrow=block;html=1;fontSize=11;fontColor=#9673a6;exitX=0.5;exitY=1;entryX=0.5;entryY=1;rounded=1;curved=1;" edge="1" parent="1" source="pro" target="pro">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="500" y="250"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- Notes -->
        <mxCell id="note1" value="Auto-downgrade khi login:&#xa;AuthController kiểm tra&#xa;membership_expired_at &lt; now()&#xa;thì UPDATE SET membership='free'" style="text;html=1;fontSize=10;align=left;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="280" width="230" height="70" as="geometry" />
        </mxCell>

        <!-- Final state -->
        <mxCell id="end" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#333333;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="90" y="380" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="st2" value="Tài khoản bị xóa" style="endArrow=block;html=1;fontSize=10;fontColor=#666666;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="170" y="200"/><mxPoint x="105" y="380"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
