<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Sequence - Speaking AI">
    <mxGraphModel>
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <mxCell id="title" value="Sequence Diagram — Luyện nói AI" style="text;html=1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="5" width="300" height="25" as="geometry" />
        </mxCell>

        <mxCell id="l1" value="Browser&#xa;(Web Speech API)" style="shape=umlLifeline;participantLabel=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;container=1;collapsible=0;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="40" width="110" height="600" as="geometry" /></mxCell>
        <mxCell id="l2" value="SpeakingController&#xa;(/speaking/score)" style="shape=umlLifeline;participantLabel=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;container=1;collapsible=0;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="200" y="40" width="125" height="600" as="geometry" /></mxCell>
        <mxCell id="l3" value="OpenAIService" style="shape=umlLifeline;participantLabel=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;container=1;collapsible=0;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="390" y="40" width="105" height="600" as="geometry" /></mxCell>
        <mxCell id="l4" value="OpenAI API" style="shape=umlLifeline;participantLabel=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;container=1;collapsible=0;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="560" y="40" width="105" height="600" as="geometry" /></mxCell>
        <mxCell id="l5" value="Model + DB" style="shape=umlLifeline;participantLabel=0;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;container=1;collapsible=0;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="730" y="40" width="105" height="600" as="geometry" /></mxCell>

        <!-- Steps -->
        <mxCell id="m1" value="1. Web Speech API&#xa;→ transcript + confidence" style="html=1;verticalAlign=bottom;fontSize=9;align=center;" vertex="1" parent="1"><mxGeometry x="25" y="90" width="130" height="30" as="geometry" /></mxCell>

        <mxCell id="m2" value="2. POST /speaking/score&#xa;JSON {prompt_id, transcript,&#xa;confidence}" style="html=1;verticalAlign=bottom;fontSize=9;align=left;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="30" y="150" width="190" height="38" as="geometry" /></mxCell>

        <mxCell id="m3" value="3. getPrompt(promptId)&#xa;→ prompt + sample_answer" style="html=1;verticalAlign=bottom;fontSize=9;align=left;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="205" y="215" width="165" height="28" as="geometry" /></mxCell>

        <mxCell id="m4" value="4. if isAvailable():&#xa;scoreSpeaking(transcript,&#xa;sample_answer)" style="html=1;verticalAlign=bottom;fontSize=9;align=left;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="205" y="275" width="170" height="38" as="geometry" /></mxCell>

        <mxCell id="m5" value="POST /v1/chat/completions&#xa;(GPT-3.5 Turbo)" style="html=1;verticalAlign=bottom;fontSize=9;align=left;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="395" y="340" width="160" height="28" as="geometry" /></mxCell>

        <mxCell id="m6" value="AI scores JSON" style="html=1;verticalAlign=top;fontSize=9;dashed=1;align=center;" vertex="1" parent="1"><mxGeometry x="395" y="395" width="120" height="18" as="geometry" /></mxCell>

        <mxCell id="m7" value="5. if !scores: local scoring&#xa;(word matching + similar_text)" style="html=1;verticalAlign=bottom;fontSize=9;align=left;spacingLeft=6;fontColor=#D79B00;" vertex="1" parent="1"><mxGeometry x="205" y="440" width="190" height="28" as="geometry" /></mxCell>

        <mxCell id="m8" value="6. saveAttempt(user, prompt,&#xa;transcript, scores) → INSERT" style="html=1;verticalAlign=bottom;fontSize=9;align=left;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="205" y="495" width="190" height="28" as="geometry" /></mxCell>

        <!-- NEW steps -->
        <mxCell id="m9" value="7. UPDATE user_progress&#xa;(speaking_practiced + addScore)" style="html=1;verticalAlign=bottom;fontSize=9;align=left;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="205" y="550" width="190" height="28" as="geometry" /></mxCell>

        <mxCell id="m10" value="8. if overall_score >= 30:&#xa;addXP(user, 30, 'speaking_practice')" style="html=1;verticalAlign=bottom;fontSize=9;align=left;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="205" y="605" width="200" height="28" as="geometry" /></mxCell>

        <mxCell id="m11" value="9. JSON {success, attempt_id,&#xa;scores, transcript, ai_used}" style="html=1;verticalAlign=top;fontSize=9;dashed=1;align=left;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="60" y="640" width="210" height="28" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
